# Mortgage Bot Environment Variables
# Copy this file to .env and fill in the values

# OpenAI API Key for embeddings and RAG
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Database Configuration
DATABASE_URL=postgresql://saga_user:saga_password@ai_infra_postgres:5432/saga_db

# Redis Configuration
REDIS_URL=redis://ai_infra_redis:6379/0

# Vector Store Configuration
VECTOR_STORE_PROVIDER=pgvector
VECTOR_STORE_COLLECTION_NAME=knowledge

# Frontend API URL (for Vite build)
VITE_API_URL=http://localhost:8008
