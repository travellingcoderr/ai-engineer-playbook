azure_subscription_id = "00000000-0000-0000-0000-000000000000"

resource_group_name = "rg-rag-system-dev"
location            = "eastus"

acr_name       = "ragsystemacrdev"
aks_name       = "aks-rag-system-dev"
aks_node_count = 1
aks_vm_size    = "Standard_DC2as_v5"
aks_node_pool_max_surge = "0"
aks_namespace  = "rag-system-dev"

key_vault_name      = "kv-rag-system-dev001"
enable_rbac_role_assignments = true
enable_app_routing  = true
enable_keyvault_csi = true

github_actions_client_id               = "11111111-1111-1111-1111-111111111111"
enable_github_actions_role_assignments = true
enable_github_actions_subscription_role_assignments = true
enable_github_actions_subscription_contributor = true
enable_github_actions_user_access_administrator = true

key_vault_secrets_officer_object_ids = [
  "22222222-2222-2222-2222-222222222222"
]
