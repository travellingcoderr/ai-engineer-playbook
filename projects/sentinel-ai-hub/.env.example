# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=""
# AZURE_AI_PROJECT_CONNECTION_STRING="eastus.api.azureml.ms;..."
AZURE_AI_AGENT_ID="..." # Created via Portal or Script
# Do not set AZURE_AI_AGENTS_API_VERSION for the OpenAI-compatible runtime.
# azure-ai-projects manages the correct /openai/v1 endpoint internally.

# Azure Search
AZURE_SEARCH_ENDPOINT="https://<name>.search.windows.net"
AZURE_SEARCH_KEY="..."
AZURE_SEARCH_INDEX_NAME="sentinel-index"

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://<name>.cognitiveservices.azure.com"
AZURE_DOCUMENT_INTELLIGENCE_KEY="..."

# Event Hubs
EVENTHUB_CONNECTION_STR="Endpoint=sb://<name>.servicebus.windows.net/;SharedAccessKeyName=..."
EVENTHUB_NAME="sentinel-events"

# OpenAI (for embeddings if not using Azure OpenAI Service)
OPENAI_API_KEY="..."
AZURE_OPENAI_DEPLOYMENT="gpt-4o" # Must match an actual model deployment name in your Foundry/Azure OpenAI resource

# Slack & Google Maps (MCP)
SLACK_BOT_TOKEN="xoxb-..."
GOOGLE_MAPS_API_KEY="..."

# App Settings
LOG_LEVEL="INFO"
